# Base PostgreSQL (obligatoire — plus de SQLite en production)
# Ex. Neon, Supabase, Vercel Postgres, ou Docker local (`docker compose up -d`) :
# postgresql://postgres:postgres@127.0.0.1:5433/incubateur?schema=public
# (le compose du projet expose Postgres sur le port 5433 pour éviter les conflits avec un PG local sur 5432)
DATABASE_URL=

# NextAuth v5 — générer avec : openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=

# URL publique de l’app (Vercel : https://votre-projet.vercel.app)
NEXTAUTH_URL=
AUTH_URL=
APP_BASE_URL=

# Stripe (paiements carte — montants en XOF)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CinetPay (Mobile Money)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_WEBHOOK_TOKEN=

# Optionnel — inscription admin protégée
ADMIN_INVITE_CODE=

# Optionnel — reset mot de passe (sinon AUTH_SECRET est utilisé)
RESET_PASSWORD_SECRET=
